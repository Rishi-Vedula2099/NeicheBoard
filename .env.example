# NeicheBoard Environment Variables Example

# --- CORE ---
PROJECT_NAME=NeicheBoard
ENVIRONMENT=development # development, production

# --- AUTH ---
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=your_super_secret_jwt_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# --- DATABASE ---
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=neicheboard
DATABASE_URL=postgresql://user:pass@db:5432/neicheboard

# --- REDIS / CELERY ---
REDIS_URL=redis://redis:6379/0

# --- AI (LOCAL OLLAMA) ---
OLLAMA_HOST=http://ollama:11434
# Optional: Model name to use (e.g., llama3, mistral)
OLLAMA_MODEL=llama3

# --- EXTERNAL SERVICES (OPTIONAL) ---
# If you decide to use cloud LLMs instead of local Ollama
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# For Email Notifications (Contract System)
# RESEND_API_KEY=re_...
# MAIL_FROM=noreply@neicheboard.com

# --- FRONTEND ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
